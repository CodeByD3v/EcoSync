# EcoSync Environment Configurations

# [REQUIRED] Insert your Gemini API Key here to enable real-time, context-aware AI insights.
# If left empty, the platform falls back to a smart heuristic recommendation engine.
GEMINI_API_KEY=your_gemini_api_key_here

# [OPTIONAL] Database, LLM and Server overrides (uncomment to customize)
# ECOSYNC_DB_PATH=ecosync.db
# LLM_MODEL=gemini-1.5-flash
# LLM_TEMPERATURE=0.2
# PORT=8000
# ECOSYNC_RELOAD=True
