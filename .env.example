# EcoSync Environment Configurations

# [REQUIRED] Insert your Gemini API Key here to enable real-time, context-aware AI insights.
# If left empty, the platform falls back to a smart heuristic recommendation engine.
GEMINI_API_KEY=your_gemini_api_key_here

# [OPTIONAL] Real-time Grid intensity API key (Electricity Maps)
# If left empty, the platform falls back to a smart, hour-of-day solar intensity calculation.
# ELECTRICITY_MAPS_API_KEY=your_electricity_maps_key_here

# [OPTIONAL] OpenWeatherMap API key for real-time location-based environmental data
# Used for local air quality, weather impact on grid, and neighborhood carbon context.
# Get a free key at: https://openweathermap.org/api
# OPENWEATHER_API_KEY=your_openweather_api_key_here

# [OPTIONAL] Google Maps API key for higher-accuracy reverse geocoding and PIN-code coordinates.
# Enable Geocoding API for this key in Google Cloud.
# GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# [OPTIONAL] Automated footprint connectors. These must be real provider credentials.
# PLAID_CLIENT_ID=your_plaid_client_id_here
# PLAID_SECRET=your_plaid_secret_here
# PLAID_ENV=sandbox
# GOOGLE_FIT_CLIENT_ID=your_google_fit_client_id_here
# GOOGLE_FIT_CLIENT_SECRET=your_google_fit_client_secret_here
# UTILITY_API_BASE_URL=https://utility-provider.example/api
# UTILITY_API_KEY=your_utility_api_key_here
# ECOSYNC_CONNECTOR_TIMEOUT_SECONDS=5

# [OPTIONAL] Database, LLM and Server overrides (uncomment to customize)
# ECOSYNC_DB_PATH=ecosync.db
# LLM_MODEL=gemini-3.5-flash
# LLM_TEMPERATURE=0.2
# PORT=8000
# ECOSYNC_RELOAD=True

# [OPTIONAL] Google Maps JavaScript API key for frontend embedded map.
# This is passed to the frontend build via VITE_GOOGLE_MAPS_API_KEY.
# VITE_GOOGLE_MAPS_API_KEY=your_google_maps_js_api_key_here
