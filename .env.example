# ─── EcoSync Environment Configuration ────────────────────────────────────────
#
# Copy this file to .env and fill in your keys.
# Lines beginning with # are comments and are ignored.
# NEVER commit a .env file containing real secrets to version control.

# ── AI / LLM ──────────────────────────────────────────────────────────────────

# [REQUIRED] Gemini API key — enables real-time AI insights and onboarding NLP.
# Without this key the platform falls back to a rule-based heuristic engine.
# Get one free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# [OPTIONAL] Override the Gemini model used for insights and onboarding parsing.
# Valid values: gemini-2.0-flash-exp (default, fast+cheap), gemini-1.5-flash, gemini-1.5-flash-8b
# LLM_MODEL=gemini-2.0-flash-exp

# [OPTIONAL] Generation temperature (0.0–1.0). Lower = more deterministic JSON output.
# LLM_TEMPERATURE=0.2

# ── Real-time Grid & Environment APIs ─────────────────────────────────────────

# [OPTIONAL] Electricity Maps API key — live grid carbon intensity per city/zone.
# Falls back to time-of-day solar heuristic when not set.
# Get one at: https://api-portal.electricitymaps.com
# ELECTRICITY_MAPS_API_KEY=your_electricity_maps_key_here

# [OPTIONAL] OpenWeatherMap API key — real-time weather and air quality data.
# Get a free key at: https://openweathermap.org/api
# OPENWEATHER_API_KEY=your_openweather_api_key_here

# ── Google Maps ───────────────────────────────────────────────────────────────

# [OPTIONAL] Google Maps Geocoding API key — higher-accuracy reverse geocoding.
# Enable "Geocoding API" for this key in Google Cloud Console.
# GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# [OPTIONAL] Google Maps JavaScript API key — enables the embedded map in Auto-Sync.
# Enable "Maps JavaScript API" + "Maps Embed API" in Google Cloud Console.
# This value is injected into the Vite frontend build at compile time.
# VITE_GOOGLE_MAPS_API_KEY=your_google_maps_js_api_key_here

# ── Automated Footprint Connectors ────────────────────────────────────────────

# [OPTIONAL] Plaid — financial transaction scraping for automatic spend categorisation.
# PLAID_CLIENT_ID=your_plaid_client_id_here
# PLAID_SECRET=your_plaid_secret_here
# PLAID_ENV=sandbox

# [OPTIONAL] Google Fit — mobility detection (walk/drive/transit auto-classification).
# GOOGLE_FIT_CLIENT_ID=your_google_fit_client_id_here
# GOOGLE_FIT_CLIENT_SECRET=your_google_fit_client_secret_here

# [OPTIONAL] Utility meter API — pulls real kWh instead of slider estimates.
# UTILITY_API_BASE_URL=https://your-utility-provider.example/api
# UTILITY_API_KEY=your_utility_api_key_here

# [OPTIONAL] Timeout (seconds) for all external connector HTTP calls.
# ECOSYNC_CONNECTOR_TIMEOUT_SECONDS=5

# ── Frontend ──────────────────────────────────────────────────────────────────

# [OPTIONAL] Override the backend API origin for the frontend.
# Leave unset in local dev (Vite proxy handles /api → localhost:8000).
# Set to your deployed backend URL in production if frontend/backend are on different origins.
# VITE_API_BASE_URL=https://your-backend-url.run.app

# ── Server & Database ─────────────────────────────────────────────────────────

# [OPTIONAL] SQLite database file path (relative to the backend/ directory).
# ECOSYNC_DB_PATH=ecosync.db

# [OPTIONAL] Listening port for uvicorn (Cloud Run injects $PORT automatically).
# PORT=8000

# [OPTIONAL] Enable uvicorn hot-reload in development. Set to False in production.
# ECOSYNC_RELOAD=True
