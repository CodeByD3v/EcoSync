# ─── EcoSync Frontend Environment Variables ───────────────────────────────────
#
# Copy to frontend/.env.local for local development.
# These variables are injected at Vite build time (VITE_ prefix required).

# [OPTIONAL] Override the backend API base URL.
# Leave unset in local dev — Vite's dev proxy (vite.config.js) forwards /api
# to http://localhost:8000 automatically.
# Set this when deploying frontend and backend to separate origins.
# VITE_API_BASE_URL=https://your-backend-url.run.app

# [OPTIONAL] Google Maps JavaScript API key for the embedded map in Auto-Sync.
# Enable "Maps JavaScript API" + "Maps Embed API" in Google Cloud Console.
# VITE_GOOGLE_MAPS_API_KEY=your_google_maps_js_api_key_here
