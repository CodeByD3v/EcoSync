# Optional: point the dashboard at an API on a different origin.
# Leave unset to use the Vite dev proxy (local) or same-origin (production).
# VITE_API_BASE_URL=https://ecosync-xxxx.run.app

# [OPTIONAL] Google Maps JavaScript API key for embedded location map.
# Enable Maps JavaScript API for this key in Google Cloud Console.
# VITE_GOOGLE_MAPS_API_KEY=your_google_maps_js_api_key_here
