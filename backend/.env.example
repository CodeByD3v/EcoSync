# SQLite Database Configurations
# In local development, the database file (ecosync.db) will be created automatically.
ECOSYNC_DB_PATH=ecosync.db

# LLM Prompt Engine Configurations (Prompt Wars Integration)
# Insert your Gemini API Key here to enable real-time, context-aware AI sustainability insights.
# If left empty, the engine falls back to a smart, rule-based heuristic recommendations engine.
GEMINI_API_KEY=your_gemini_api_key_here
LLM_MODEL=gemini-1.5-flash
LLM_TEMPERATURE=0.2

# Server Configurations
ECOSYNC_RELOAD=True
PORT=8000
